@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <i class="bi bi-cart3 fs-4 text-success"></i>
    <h4 class="mb-0">Shopping Cart</h4>
    <span id="cartBadge" class="badge bg-success ms-1"></span>
</div>

<div id="cartContainer">
    <div class="text-center py-5">
        <i class="bi bi-cart-x" style="font-size:4rem;color:#ccc;"></i>
        <h5 class="mt-3 text-muted">Your cart is empty</h5>
        <a href="/Customer" class="btn btn-success mt-2">
            <i class="bi bi-bag me-1"></i> Continue Shopping
        </a>
    </div>
</div>

<div id="checkoutSection" style="display: none;">
    <hr class="my-4" />
    <div class="row g-4">
        <div class="col-lg-7">

            <div class="card shadow-sm mb-3">
                <div class="card-header bg-success text-white d-flex align-items-center gap-2">
                    <i class="bi bi-geo-alt-fill"></i>
                    <h6 class="mb-0">Delivery Address</h6>
                </div>
                <div class="card-body">
                    @if ((ViewBag.Addresses?.Count ?? 0) > 0)
                    {
                        @foreach (var address in ViewBag.Addresses)
                        {
                            <div class="form-check border rounded p-3 mb-2 address-option">
                                <input class="form-check-input" type="radio" name="addressId"
                                       value="@address.AddressId" id="addr_@address.AddressId"
                                       @(address.IsDefault ? "checked" : "") />
                                <label class="form-check-label w-100" for="addr_@address.AddressId">
                                    <span class="badge @(address.IsDefault ? "bg-success" : "bg-secondary") me-2">
                                        @address.Label
                                    </span>
                                    @if (address.IsDefault)
                                    {
                                        <span class="badge bg-warning text-dark me-1">Default</span>
                                    }
                                    <br />
                                    <span class="text-muted small mt-1 d-block">@address.Address1</span>
                                </label>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            No addresses found. <a asp-action="AddAddress">Add an address</a> first.
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-success text-white d-flex align-items-center gap-2">
                    <i class="bi bi-ticket-perforated-fill"></i>
                    <h6 class="mb-0">Coupon</h6>
                </div>
                <div class="card-body">
                    <select id="couponSelect" class="form-select">
                        <option value="">— No Coupon —</option>
                        @foreach (var coupon in ViewBag.Coupons ?? new List<fffff.Models.Db.UserCoupon>())
                        {
                            <option value="@coupon.Id" data-discount="@coupon.Coupon?.DiscountPercent">
                                🎟 @coupon.Coupon?.Code — @coupon.Coupon?.DiscountPercent% OFF
                            </option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white d-flex align-items-center gap-2">
                    <i class="bi bi-receipt"></i>
                    <h6 class="mb-0">Order Summary</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between text-muted mb-2">
                        <span>Subtotal</span>
                        <span id="subtotal">฿0.00</span>
                    </div>
                    <div class="d-flex justify-content-between text-danger mb-2">
                        <span>Discount</span>
                        <span id="discount">-฿0.00</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Total</h5>
                        <h4 id="total" class="mb-0 text-success fw-bold">฿0.00</h4>
                    </div>
                    <div class="d-grid">
                        <button id="checkoutBtn" class="btn btn-success btn-lg"
                                @(ViewBag.Addresses?.Count == 0 ? "disabled" : "")>
                            <i class="bi bi-credit-card me-1"></i> Place Order
                        </button>
                    </div>
                    @if ((ViewBag.Addresses?.Count ?? 0) == 0)
                    {
                        <div class="text-center text-muted small mt-2">
                            Please add an address first
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cart-item-card {
        border: 1px solid #dee2e6;
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 10px;
        background: #fff;
        transition: box-shadow .15s;
    }
    .cart-item-card:hover { box-shadow: 0 2px 10px rgba(0,0,0,.1); }
    .address-option:has(input:checked) { border-color: #198754 !important; background: #f0fff4; }
</style>

@section Scripts {
    <script>
        let cart = [];

        function renderCart() {
            cart = JSON.parse(sessionStorage.getItem('cart') || '[]');
            const container = document.getElementById('cartContainer');
            const badge = document.getElementById('cartBadge');

            if (cart.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-5">
                        <i class="bi bi-cart-x" style="font-size:4rem;color:#ccc;"></i>
                        <h5 class="mt-3 text-muted">Your cart is empty</h5>
                        <a href="/Customer" class="btn btn-success mt-2">
                            <i class="bi bi-bag me-1"></i> Continue Shopping
                        </a>
                    </div>`;
                document.getElementById('checkoutSection').style.display = 'none';
                badge.textContent = '';
                return;
            }

            badge.textContent = cart.length + ' item' + (cart.length > 1 ? 's' : '');

            let html = '';
            let subtotal = 0;
            cart.forEach((item, index) => {
                const total = item.price * item.quantity;
                subtotal += total;
                html += `
                <div class="cart-item-card d-flex align-items-center gap-3">
                    <div style="width:48px;height:48px;background:#f0fff4;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="bi bi-shoe2 fs-4 text-success"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold">${item.brand} ${item.model}</div>
                        <div class="text-muted small">Size: ${item.size} &nbsp;|&nbsp; Qty: ${item.quantity}</div>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold text-success">฿${total.toFixed(2)}</div>
                        <div class="text-muted small">฿${parseFloat(item.price).toFixed(2)} each</div>
                    </div>
                    <button class="btn btn-sm btn-outline-danger ms-2" onclick="removeItem(${index})" title="Remove">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>`;
            });

            container.innerHTML = html;
            document.getElementById('checkoutSection').style.display = 'block';
            updateSummary(subtotal);
        }

        function removeItem(index) {
            cart.splice(index, 1);
            sessionStorage.setItem('cart', JSON.stringify(cart));
            renderCart();
        }

        function updateSummary(subtotal) {
            const couponSelect = document.getElementById('couponSelect');
            const selectedOption = couponSelect.options[couponSelect.selectedIndex];
            const discountPct = selectedOption.dataset.discount ? parseInt(selectedOption.dataset.discount) : 0;
            const discount = subtotal * discountPct / 100;
            const total = subtotal - discount;

            document.getElementById('subtotal').textContent = '฿' + subtotal.toFixed(2);
            document.getElementById('discount').textContent = '-฿' + discount.toFixed(2);
            document.getElementById('total').textContent = '฿' + total.toFixed(2);

            return { subtotal, discount, total };
        }

        document.getElementById('couponSelect')?.addEventListener('change', function () {
            let subtotal = 0;
            cart.forEach(item => subtotal += item.price * item.quantity);
            updateSummary(subtotal);
        });

        document.getElementById('checkoutBtn')?.addEventListener('click', function () {
            const addressId = document.querySelector('input[name="addressId"]:checked')?.value;
            if (!addressId) {
                alert('Please select a delivery address');
                return;
            }

            const summary = updateSummary(cart.reduce((sum, item) => sum + item.price * item.quantity, 0));
            const couponId = document.getElementById('couponSelect').value;
            const items = cart.map(item => `${item.productId},${item.size},${item.quantity},${item.price}`).join(';');

            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Customer/Checkout';

            const fields = {
                addressId: addressId,
                userCouponId: couponId || '',
                totalPrice: summary.total,
                items: items
            };

            for (const [key, value] of Object.entries(fields)) {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = key;
                input.value = value;
                form.appendChild(input);
            }

            document.body.appendChild(form);
            form.submit();
        });

        renderCart();
    </script>
}
