@model fffff.Models.Db.Order
@{
    ViewData["Title"] = $"Order #{Model.OrderId}";
}

<h2><i class="bi bi-bag-check"></i> Order #@Model.OrderId</h2>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Order Items</h5>
            </div>
            <div class="card-body">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Product ID</th>
                            <th>Size</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>@item.ProductId</td>
                                <td>@item.Size</td>
                                <td>@item.Quantity</td>
                                <td>@item.Price?.ToString("C")</td>
                                <td>@((item.Price * item.Quantity)?.ToString("C"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Order Summary</h5>
            </div>
            <div class="card-body">
                <p><strong>Status:</strong> <span class="badge @(Model.Status == "Completed" ? "bg-success" : Model.Status == "Pending" ? "bg-warning" : "bg-info")">@Model.Status</span></p>
                <p><strong>Date:</strong> @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Total:</strong> <span class="h5 text-success">@Model.TotalPrice?.ToString("C")</span></p>
            </div>
        </div>
        
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Delivery Address</h5>
            </div>
            <div class="card-body">
                <span class="badge bg-secondary">@Model.Address?.Label</span>
                <p class="mt-2">@Model.Address?.Address1</p>
            </div>
        </div>
        
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Shipping Status</h5>
            </div>
            <div class="card-body">
                @if (Model.Shipments?.Any() == true)
                {
                    var shipment = Model.Shipments.First();
                    <p><strong>Status:</strong> @shipment.Status</p>
                    @if (!string.IsNullOrEmpty(shipment.TrackingNumber))
                    {
                        <p><strong>Tracking:</strong> @shipment.TrackingNumber</p>
                    }
                }
                else
                {
                    <p class="text-muted">Not shipped yet</p>
                }
            </div>
        </div>
    </div>
</div>

<a asp-action="Orders" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left"></i> Back to Orders
</a>
<a asp-action="Receipt" asp-route-id="@Model.OrderId" class="btn btn-success">
    <i class="bi bi-receipt"></i> View Receipt
</a>
