@model fffff.Models.Db.Order
@{
    ViewData["Title"] = $"Order #{Model.OrderId}";
    var statusColor = Model.Status switch {
        "Completed"  => "success",
        "Pending"    => "warning",
        "Processing" => "primary",
        "Shipped"    => "info",
        "Cancelled"  => "danger",
        _            => "secondary"
    };
    var statusIcon = Model.Status switch {
        "Completed"  => "bi-check-circle-fill",
        "Pending"    => "bi-clock-fill",
        "Processing" => "bi-gear-fill",
        "Shipped"    => "bi-truck",
        "Cancelled"  => "bi-x-circle-fill",
        _            => "bi-circle"
    };
    var steps = new[] { "Pending", "Processing", "Shipped", "Completed" };
    var currentStep = Array.IndexOf(steps, Model.Status);
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Orders" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    <h4 class="mb-0">Order <span class="text-muted">#@Model.OrderId</span></h4>
    <span class="badge bg-@statusColor ms-1 px-3 py-2">
        <i class="bi @statusIcon me-1"></i>@Model.Status
    </span>
    <a asp-action="Receipt" asp-route-id="@Model.OrderId" class="btn btn-outline-success btn-sm ms-auto">
        <i class="bi bi-receipt me-1"></i> Receipt
    </a>
</div>

@if (Model.Status != "Cancelled")
{
    <div class="card shadow-sm mb-4">
        <div class="card-body py-4">
            <div class="d-flex justify-content-between align-items-center position-relative">
                <div style="position:absolute;top:20px;left:10%;right:10%;height:3px;background:#dee2e6;z-index:0;"></div>
                <div style="position:absolute;top:20px;left:10%;width:@(currentStep < 0 ? 0 : currentStep * 100 / (steps.Length - 1))%;height:3px;background:#198754;z-index:1;transition:width .4s;"></div>
                @for (int i = 0; i < steps.Length; i++)
                {
                    var done = i <= currentStep;
                    var active = i == currentStep;
                    <div class="d-flex flex-column align-items-center" style="z-index:2;width:25%;">
                        <div style="width:40px;height:40px;border-radius:50%;background:@(done ? "#198754" : "#dee2e6");display:flex;align-items:center;justify-content:center;border:3px solid @(done ? "#198754" : "#dee2e6");">
                            @if (done)
                            {
                                <i class="bi bi-check-lg text-white fw-bold"></i>
                            }
                            else
                            {
                                <span class="text-muted small">@(i + 1)</span>
                            }
                        </div>
                        <div class="mt-2 small fw-semibold @(active ? "text-success" : done ? "text-success" : "text-muted")">
                            @steps[i]
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">

        <div class="card shadow-sm">
            <div class="card-header py-3 d-flex align-items-center gap-2" style="background:linear-gradient(135deg,#198754,#146c43);">
                <i class="bi bi-bag-check-fill text-white"></i>
                <h6 class="mb-0 text-white fw-bold">Order Items</h6>
                <span class="badge bg-light text-dark ms-auto">@Model.OrderItems.Count items</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="ps-4 py-3 text-muted small fw-semibold">PRODUCT</th>
                            <th class="py-3 text-muted small fw-semibold">SIZE</th>
                            <th class="py-3 text-muted small fw-semibold">QTY</th>
                            <th class="py-3 text-muted small fw-semibold">UNIT PRICE</th>
                            <th class="py-3 pe-4 text-muted small fw-semibold text-end">TOTAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="width:42px;height:42px;background:#f0fff4;border-radius:8px;display:flex;align-items:center;justify-content:center;">
                                            <i class="bi bi-shoe2 text-success fs-5"></i>
                                        </div>
                                        <span class="fw-semibold">Product #@item.ProductId</span>
                                    </div>
                                </td>
                                <td><span class="badge bg-light text-dark border">#@item.Size</span></td>
                                <td><span class="fw-semibold">x@item.Quantity</span></td>
                                <td class="text-muted">฿@item.Price?.ToString("N0")</td>
                                <td class="pe-4 text-end fw-bold text-success">
                                    ฿@((item.Price * item.Quantity)?.ToString("N0"))
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot style="background:#f8f9fa;border-top:2px solid #dee2e6;">
                        <tr>
                            <td colspan="4" class="ps-4 py-3 fw-bold text-end">Grand Total</td>
                            <td class="pe-4 py-3 fw-bold text-success fs-5 text-end">
                                ฿@Model.TotalPrice?.ToString("N0")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

    </div>

    <div class="col-lg-4">

        <div class="card shadow-sm mb-3">
            <div class="card-header py-3 d-flex align-items-center gap-2">
                <i class="bi bi-info-circle-fill text-success"></i>
                <h6 class="mb-0 fw-bold">Order Info</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Order Date</span>
                    <span class="small fw-semibold">@Model.CreatedAt?.ToString("dd MMM yyyy")</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Time</span>
                    <span class="small">@Model.CreatedAt?.ToString("HH:mm")</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted small">Status</span>
                    <span class="badge bg-@statusColor">@Model.Status</span>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-header py-3 d-flex align-items-center gap-2">
                <i class="bi bi-geo-alt-fill text-success"></i>
                <h6 class="mb-0 fw-bold">Delivery Address</h6>
            </div>
            <div class="card-body">
                <span class="badge bg-success mb-2">@Model.Address?.Label</span>
                <p class="text-muted mb-0 small">@Model.Address?.Address1</p>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header py-3 d-flex align-items-center gap-2">
                <i class="bi bi-truck text-success"></i>
                <h6 class="mb-0 fw-bold">Shipping</h6>
            </div>
            <div class="card-body">
                @if (Model.Shipments?.Any() == true)
                {
                    var ship = Model.Shipments.First();
                    var shipColor = ship.Status == "Delivered" ? "success" : ship.Status == "Pending" ? "warning" : "info";
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">Status</span>
                        <span class="badge bg-@shipColor">@ship.Status</span>
                    </div>
                    @if (!string.IsNullOrEmpty(ship.TrackingNumber))
                    {
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Tracking No.</span>
                            <code class="small bg-light px-2 py-1 rounded">@ship.TrackingNumber</code>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">Tracking number not yet assigned</p>
                    }
                }
                else
                {
                    <div class="text-center py-2">
                        <i class="bi bi-clock text-muted fs-4"></i>
                        <p class="text-muted small mt-1 mb-0">Not shipped yet</p>
                    </div>
                }
            </div>
        </div>

    </div>
</div>
