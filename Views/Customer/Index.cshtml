@model IEnumerable<fffff.Models.Db.Product>
@{
    ViewData["Title"] = "Products";
    var productCount = Model.Count();
    var hasFilter = !string.IsNullOrEmpty(ViewBag.Search as string)
                 || !string.IsNullOrEmpty(ViewBag.CurrentFieldType as string)
                 || !string.IsNullOrEmpty(ViewBag.CurrentBrand as string);
}

<style>
    .product-card { transition: transform .2s, box-shadow .2s; border-radius: 14px; overflow: hidden; }
    .product-card:hover { transform: translateY(-5px); box-shadow: 0 12px 28px rgba(0,0,0,.12) !important; }
    .product-img-wrap { position: relative; height: 210px; overflow: hidden; background: #f8f9fa; }
    .product-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform .3s; }
    .product-card:hover .product-img-wrap img { transform: scale(1.05); }
    .field-badge { position: absolute; top: 10px; left: 10px; }
    .size-pill { font-size: .7rem; padding: 2px 7px; border-radius: 20px; }
</style>

<div class="rounded-4 mb-4 px-4 py-4 text-white"
     style="background: linear-gradient(135deg, #198754 0%, #0f5132 100%);">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h4 class="mb-1 fw-bold"><i class="bi bi-shoe2 me-2"></i>Football Boots</h4>
            <p class="mb-0 opacity-75 small">เลือกรองเท้าฟุตบอลที่ใช่สำหรับคุณ — @productCount รายการ</p>
        </div>
        <a href="/Customer/Cart" class="btn btn-light text-success fw-semibold">
            <i class="bi bi-cart3 me-1"></i> ดูตะกร้า
        </a>
    </div>
</div>

<div class="card shadow-sm mb-4 border-0">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-3">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0">
                        <i class="bi bi-grass text-muted"></i>
                    </span>
                    <select name="fieldType" class="form-select border-start-0 bg-light">
                        <option value="">All Field Types</option>
                        @foreach (var ft in ViewBag.FieldTypes ?? new List<string>())
                        {
                            @if (ft == ViewBag.CurrentFieldType)
                            {
                                <option value="@ft" selected>@ft</option>
                            }
                            else
                            {
                                <option value="@ft">@ft</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0">
                        <i class="bi bi-tag text-muted"></i>
                    </span>
                    <select name="brand" class="form-select border-start-0 bg-light">
                        <option value="">All Brands</option>
                        @foreach (var b in ViewBag.Brands ?? new List<string>())
                        {
                            @if (b == ViewBag.CurrentBrand)
                            {
                                <option value="@b" selected>@b</option>
                            }
                            else
                            {
                                <option value="@b">@b</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" name="search" class="form-control border-start-0 bg-light"
                           placeholder="Search brand, model..." value="@ViewBag.Search" />
                </div>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-success flex-grow-1">
                    <i class="bi bi-funnel-fill me-1"></i> Filter
                </button>
                @if (hasFilter)
                {
                    <a href="/Customer/Index" class="btn btn-outline-secondary" title="Clear">
                        <i class="bi bi-x-lg"></i>
                    </a>
                }
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-search text-muted" style="font-size:3rem;"></i>
        <h5 class="mt-3 text-muted">ไม่พบสินค้าที่ค้นหา</h5>
        <a href="/Customer/Index" class="btn btn-outline-success mt-2">ล้างตัวกรอง</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var product in Model)
        {
            var fieldClass = product.FieldType switch {
                "Real Grass"      => "bg-success",
                "Artificial Turf" => "bg-warning text-dark",
                "Indoor"          => "bg-info text-dark",
                _                 => "bg-secondary"
            };
            var inStock = product.ProductSizes.Any(s => s.Stock > 0);

            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="card h-100 shadow-sm product-card border-0">
                    <div class="product-img-wrap">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" alt="@product.Model" />
                        }
                        else
                        {
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center"
                                 style="background:linear-gradient(135deg,#e9f7ef,#d1e7dd);">
                                <i class="bi bi-shoe2 text-success" style="font-size:4rem;opacity:.5;"></i>
                            </div>
                        }
                        <span class="badge @fieldClass field-badge">@product.FieldType</span>
                        @if (!inStock)
                        {
                            <span class="badge bg-dark position-absolute bottom-0 end-0 m-2">Out of Stock</span>
                        }
                    </div>

                    <div class="card-body px-3 pt-3 pb-2">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="fw-bold mb-0">@product.Brand</h6>
                                <p class="text-muted small mb-2">@product.Model</p>
                            </div>
                            <span class="fw-bold text-success">฿@product.Price?.ToString("N0")</span>
                        </div>

                        <div class="d-flex flex-wrap gap-1 mt-1">
                            @foreach (var ps in product.ProductSizes)
                            {
                                <span class="size-pill border @(ps.Stock > 0 ? "border-success text-success" : "border-secondary text-muted text-decoration-line-through")">
                                    @ps.Size
                                </span>
                            }
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 px-3 pb-3">
                        <a asp-action="ProductDetails" asp-route-id="@product.ProductId"
                           class="btn btn-success w-100 @(!inStock ? "disabled" : "")">
                            <i class="bi bi-eye me-1"></i> View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
