@model IEnumerable<fffff.Models.Db.Product>
@{
    ViewData["Title"] = "Inventory Management";
    var totalProducts  = Model.Count();
    var lowStockCount  = Model.Count(p => p.ProductSizes.Any(s => s.Stock < 5));
    var totalStock     = Model.Sum(p => p.ProductSizes.Sum(s => s.Stock));
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-0"><i class="bi bi-box-seam me-2 text-success"></i>Inventory Management</h4>
        <small class="text-muted">จัดการสินค้าและสต็อกทั้งหมดในระบบ</small>
    </div>
    <a asp-action="AddProduct" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i> Add Product
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm" style="border-left:4px solid #198754 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width:48px;height:48px;background:#d1e7dd;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-box-seam-fill text-success fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-success">@totalProducts</div>
                    <div class="text-muted small">Total Products</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm" style="border-left:4px solid #ffc107 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width:48px;height:48px;background:#fff3cd;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-exclamation-triangle-fill text-warning fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-warning">@lowStockCount</div>
                    <div class="text-muted small">Low Stock (&lt; 5)</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm" style="border-left:4px solid #0d6efd !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width:48px;height:48px;background:#cfe2ff;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-layers-fill text-primary fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-primary">@totalStock</div>
                    <div class="text-muted small">Total Stock</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
        <h6 class="mb-0 fw-bold"><i class="bi bi-table me-2"></i>รายการสินค้า</h6>
        <div class="col-md-4">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" id="searchInput" class="form-control border-start-0 bg-light"
                       placeholder="Search brand, model, field type..." />
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:#f8f9fa;border-bottom:2px solid #dee2e6;">
                    <tr>
                        <th class="ps-4 py-3 text-muted small fw-semibold">PRODUCT</th>
                        <th class="py-3 text-muted small fw-semibold">FIELD TYPE</th>
                        <th class="py-3 text-muted small fw-semibold">PRICE</th>
                        <th class="py-3 text-muted small fw-semibold">SIZES & STOCK</th>
                        <th class="py-3 text-muted small fw-semibold text-end pe-4">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        var isLow = product.ProductSizes.Any(s => s.Stock < 5);
                        <tr class="product-row">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" alt="@product.Model"
                                             style="width:48px;height:48px;object-fit:cover;border-radius:8px;border:1px solid #dee2e6;" />
                                    }
                                    else
                                    {
                                        <div style="width:48px;height:48px;background:#f0fff4;border-radius:8px;display:flex;align-items:center;justify-content:center;border:1px solid #dee2e6;">
                                            <i class="bi bi-shoe2 text-success fs-5"></i>
                                        </div>
                                    }
                                    <div>
                                        <div class="fw-semibold">@product.Brand</div>
                                        <div class="text-muted small">@product.Model</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @{
                                    var fieldClass = product.FieldType switch {
                                        "Real Grass"      => "bg-success",
                                        "Artificial Turf" => "bg-warning text-dark",
                                        "Indoor"          => "bg-info text-dark",
                                        _                 => "bg-secondary"
                                    };
                                }
                                <span class="badge @fieldClass">@product.FieldType</span>
                            </td>
                            <td class="fw-semibold text-success">
                                ฿@product.Price?.ToString("N0")
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var size in product.ProductSizes)
                                    {
                                        <form method="post" asp-action="UpdateStock" class="d-inline">
                                            <input type="hidden" name="sizeId" value="@size.SizeId" />
                                            <div class="input-group input-group-sm" style="width:130px;">
                                                <span class="input-group-text fw-semibold px-2"
                                                      style="background:@(size.Stock < 5 ? "#fff3cd" : "#d1e7dd");color:@(size.Stock < 5 ? "#856404" : "#155724");">
                                                    #@size.Size
                                                </span>
                                                <input type="number" name="newStock" value="@size.Stock"
                                                       class="form-control text-center" min="0" />
                                                <button type="submit" class="btn btn-outline-success px-2" title="Update">
                                                    <i class="bi bi-check"></i>
                                                </button>
                                            </div>
                                        </form>
                                    }
                                </div>
                                @if (isLow)
                                {
                                    <div class="mt-1">
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-exclamation-triangle me-1"></i>Low Stock
                                        </span>
                                    </div>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="EditProduct" asp-route-id="@product.ProductId"
                                   class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </a>
                                <form method="post" asp-action="DeleteProduct" asp-route-id="@product.ProductId"
                                      class="d-inline" onsubmit="return confirm('ลบสินค้า @product.Brand @product.Model ?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer bg-white text-muted small py-2 px-4">
        แสดง <span id="visibleCount">@totalProducts</span> / @totalProducts รายการ
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const rows = document.querySelectorAll('.product-row');
        const visibleCount = document.getElementById('visibleCount');

        searchInput.addEventListener('input', function () {
            const q = this.value.toLowerCase();
            let count = 0;
            rows.forEach(row => {
                const show = row.innerText.toLowerCase().includes(q);
                row.style.display = show ? '' : 'none';
                if (show) count++;
            });
            visibleCount.textContent = count;
        });
    </script>
}
