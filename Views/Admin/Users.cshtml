@model IEnumerable<fffff.Models.Db.User>

@{
    ViewData["Title"] = "User Management";
    var totalUsers  = Model.Count();
    var adminCount  = Model.Count(u => u.Role == "admin");
    var customerCount = Model.Count(u => u.Role == "customer");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-0"><i class="bi bi-people-fill me-2 text-success"></i>User Management</h4>
        <small class="text-muted">จัดการข้อมูลผู้ใช้งานทั้งหมดในระบบ</small>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #198754 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width:48px;height:48px;background:#d1e7dd;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-people-fill text-success fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-success">@totalUsers</div>
                    <div class="text-muted small">Total Users</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #dc3545 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width:48px;height:48px;background:#f8d7da;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-shield-fill text-danger fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-danger">@adminCount</div>
                    <div class="text-muted small">Admins</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #0d6efd !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width:48px;height:48px;background:#cfe2ff;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-person-fill text-primary fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-primary">@customerCount</div>
                    <div class="text-muted small">Customers</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
        <h6 class="mb-0 fw-bold"><i class="bi bi-table me-2"></i>รายชื่อผู้ใช้</h6>
        <div class="col-md-4">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" id="searchInput" class="form-control border-start-0 bg-light"
                       placeholder="Search username, name, email..." />
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="usersTable">
                <thead style="background:#f8f9fa;border-bottom:2px solid #dee2e6;">
                    <tr>
                        <th class="ps-4 py-3 text-muted small fw-semibold">USER</th>
                        <th class="py-3 text-muted small fw-semibold">EMAIL</th>
                        <th class="py-3 text-muted small fw-semibold">ROLE</th>
                        <th class="py-3 text-muted small fw-semibold">JOINED</th>
                        <th class="py-3 text-muted small fw-semibold text-end pe-4">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr class="user-row">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:40px;height:40px;border-radius:50%;background:@(user.Role == "admin" ? "#f8d7da" : "#d1e7dd");display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <i class="bi bi-person-fill @(user.Role == "admin" ? "text-danger" : "text-success")"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@user.Username</div>
                                        <div class="text-muted small">@user.Name</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                <span class="badge rounded-pill @(user.Role == "admin" ? "bg-danger" : "bg-success") px-3 py-2">
                                    @(user.Role == "admin" ? "Admin" : "Customer")
                                </span>
                            </td>
                            <td class="text-muted small">
                                <i class="bi bi-calendar3 me-1"></i>
                                @user.CreatedAt?.ToString("dd MMM yyyy")
                            </td>
                            <td class="text-end pe-4">
                                <a href="/Admin/EditUser/@user.UserId" class="btn btn-sm btn-outline-warning me-1">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </a>
                                <form method="post" action="/Admin/DeleteUser" style="display:inline"
                                      onsubmit="return confirm('ต้องการลบ @user.Username ?')">
                                    <input type="hidden" name="id" value="@user.UserId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer bg-white text-muted small py-2 px-4">
        แสดง <span id="visibleCount">@totalUsers</span> / @totalUsers รายการ
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const rows = document.querySelectorAll('.user-row');
        const visibleCount = document.getElementById('visibleCount');

        searchInput.addEventListener('input', function () {
            const q = this.value.toLowerCase();
            let count = 0;
            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                const show = text.includes(q);
                row.style.display = show ? '' : 'none';
                if (show) count++;
            });
            visibleCount.textContent = count;
        });
    </script>
}
