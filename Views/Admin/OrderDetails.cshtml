@model fffff.Models.Db.Order
@{
    ViewData["Title"] = $"Order #{Model.OrderId}";
    var statusColor = Model.Status switch {
        "Completed"  => "success",
        "Pending"    => "warning",
        "Processing" => "primary",
        "Shipped"    => "info",
        "Cancelled"  => "danger",
        _            => "secondary"
    };
    var statusIcon = Model.Status switch {
        "Completed"  => "bi-check-circle-fill",
        "Pending"    => "bi-clock-fill",
        "Processing" => "bi-gear-fill",
        "Shipped"    => "bi-truck",
        "Cancelled"  => "bi-x-circle-fill",
        _            => "bi-circle"
    };
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Orders" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    <h4 class="mb-0">Order <span class="text-muted">#@Model.OrderId</span></h4>
    <span class="badge bg-@statusColor ms-1 px-3 py-2">
        <i class="bi @statusIcon me-1"></i>@Model.Status
    </span>
    <span class="text-muted small ms-auto">
        <i class="bi bi-calendar3 me-1"></i>@Model.CreatedAt?.ToString("dd MMM yyyy, HH:mm")
    </span>
</div>

<div class="row g-4">
    <div class="col-lg-8">

        <div class="card shadow-sm mb-4">
            <div class="card-header py-3 d-flex align-items-center gap-2" style="background:linear-gradient(135deg,#198754,#146c43);">
                <i class="bi bi-bag-check-fill text-white"></i>
                <h6 class="mb-0 text-white fw-bold">Order Items</h6>
                <span class="badge bg-light text-dark ms-auto">@Model.OrderItems.Count items</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="ps-4 py-3 text-muted small fw-semibold">PRODUCT</th>
                            <th class="py-3 text-muted small fw-semibold">SIZE</th>
                            <th class="py-3 text-muted small fw-semibold">QTY</th>
                            <th class="py-3 text-muted small fw-semibold">UNIT PRICE</th>
                            <th class="py-3 pe-4 text-muted small fw-semibold text-end">TOTAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="width:42px;height:42px;background:#f0fff4;border-radius:8px;display:flex;align-items:center;justify-content:center;">
                                            <i class="bi bi-shoe2 text-success fs-5"></i>
                                        </div>
                                        <span class="fw-semibold">Product #@item.ProductId</span>
                                    </div>
                                </td>
                                <td><span class="badge bg-light text-dark border">#@item.Size</span></td>
                                <td><span class="fw-semibold">x@item.Quantity</span></td>
                                <td class="text-muted">฿@item.Price?.ToString("N0")</td>
                                <td class="pe-4 text-end fw-bold text-success">
                                    ฿@((item.Price * item.Quantity)?.ToString("N0"))
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot style="background:#f8f9fa;border-top:2px solid #dee2e6;">
                        <tr>
                            <td colspan="4" class="ps-4 py-3 fw-bold text-end">Grand Total</td>
                            <td class="pe-4 py-3 fw-bold text-success fs-5 text-end">
                                ฿@Model.TotalPrice?.ToString("N0")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header py-3 d-flex align-items-center gap-2">
                <i class="bi bi-arrow-repeat text-success"></i>
                <h6 class="mb-0 fw-bold">Update Order Status</h6>
            </div>
            <div class="card-body">
                <form method="post" asp-action="UpdateOrderStatus" class="d-flex gap-2 align-items-end">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <div class="flex-grow-1">
                        <label class="form-label fw-semibold small text-muted">New Status</label>
                        <select id="statusSelect" name="status" class="form-select">
                            <option value="Pending">Pending</option>
                            <option value="Processing">Processing</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                        <script>document.getElementById('statusSelect').value = '@Model.Status';</script>
                    </div>
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-check-lg me-1"></i> Update
                    </button>
                </form>
            </div>
        </div>

    </div>

    <div class="col-lg-4">

        <div class="card shadow-sm mb-3">
            <div class="card-header py-3 d-flex align-items-center gap-2">
                <i class="bi bi-person-fill text-success"></i>
                <h6 class="mb-0 fw-bold">Customer Info</h6>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div style="width:44px;height:44px;background:#d1e7dd;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-person-fill text-success fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">@Model.User?.Name</div>
                        <div class="text-muted small">@Model.User?.Email</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-header py-3 d-flex align-items-center gap-2">
                <i class="bi bi-geo-alt-fill text-success"></i>
                <h6 class="mb-0 fw-bold">Delivery Address</h6>
            </div>
            <div class="card-body">
                <span class="badge bg-success mb-2">@Model.Address?.Label</span>
                <p class="text-muted mb-0">@Model.Address?.Address1</p>
            </div>
        </div>

        @if (Model.Shipments?.Any() == true)
        {
            var ship = Model.Shipments.First();
            var shipColor = ship.Status == "Delivered" ? "success" : ship.Status == "Pending" ? "warning" : "info";
            <div class="card shadow-sm">
                <div class="card-header py-3 d-flex align-items-center gap-2">
                    <i class="bi bi-truck text-success"></i>
                    <h6 class="mb-0 fw-bold">Shipment</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">Status</span>
                        <span class="badge bg-@shipColor">@ship.Status</span>
                    </div>
                    @if (!string.IsNullOrEmpty(ship.TrackingNumber))
                    {
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Tracking</span>
                            <code class="small">@ship.TrackingNumber</code>
                        </div>
                    }
                </div>
            </div>
        }

    </div>
</div>
