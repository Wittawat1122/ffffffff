@model IEnumerable<fffff.Models.Db.Order>
@{
    ViewData["Title"] = "All Orders";
}

<h2><i class="bi bi-bag"></i> All Orders</h2>

<div class="card shadow">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Address</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>#@order.OrderId</td>
                            <td>@order.User?.Name</td>
                            <td><span class="badge bg-secondary">@order.Address?.Label</span></td>
                            <td>@order.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@order.TotalPrice?.ToString("C")</td>
                            <td>
                                <span class="badge @(order.Status == "Completed" ? "bg-success" : order.Status == "Pending" ? "bg-warning" : "bg-info")">
                                    @order.Status
                                </span>
                            </td>
                            <td>
                                <a asp-action="OrderDetails" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-success">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
